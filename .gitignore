# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
release
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude Code — ignore machine-local settings and the skills junction by default.
# settings.local.json is per-machine; skills/ is a junction to the private
# claude-config repo (committing it would embed another repo's files).
# (CLAUDE.md itself is intentionally tracked and public — it carries no secrets.)
# Exception: settings.json is tracked so shared hooks (e.g. Serena enforcement)
# sync across machines/clones. Nothing in it is secret.
.claude/*
!.claude/settings.json

# Tests, docs, scripts — not needed to build
tests/*
# Exceptions: tracked tests
!tests/unit/
!tests/unit/**/*.spec.ts
!tests/unit/**/*.spec.tsx
# Exception: vitest setup files (registered via setupFiles in vitest.config.ts)
!tests/setup/
!tests/setup/**/*.ts
# Exception: the WCAG contrast lint is tracked so CI can run it
# (the existing `tests/test_*.js` runner picks it up automatically).
!tests/test_contrast.js
# Exception: curve math unit test (TS, run via npx tsx)
!tests/test_curve.ts
# Exception: fixtures used by unit tests
!tests/fixtures/
!tests/fixtures/**/*.json
# Exception: Playwright e2e specs are tracked so CI can run them
!tests/e2e/
tests/e2e/*
!tests/e2e/*.spec.ts
docs/
# Exception: superpowers design specs are tracked as versioned project artifacts
!docs/
docs/*
!docs/ARCHITECTURE.md
!docs/review-lenses.md
!docs/superpowers/
docs/superpowers/*
!docs/superpowers/specs/
!docs/superpowers/plans/
scripts/
playwright-report/
test-results/
*.original.md
.superpowers/
.worktrees/

# Signing keys (never commit private keys)
~/.tauri/

# Generated screenshots and playwright artifacts
.playwright-mcp/
skill-observations/
# Root-level screenshots (not src-tauri/icons which are needed for builds)
/*.png

# Serena MCP local files (memories + config) kept off this public repo.
.serena/
