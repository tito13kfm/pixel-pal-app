# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
release
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Dev tooling — not for public consumption
CLAUDE.md

# Tests, docs, scripts — not needed to build
tests/*
# Exceptions: tracked tests
!tests/unit/
!tests/unit/**/*.spec.ts
# Exception: the WCAG contrast lint is tracked so CI can run it
# (the existing `tests/test_*.js` runner picks it up automatically).
!tests/test_contrast.js
# Exception: curve math unit test (TS, run via npx tsx)
!tests/test_curve.ts
# Exception: fixtures used by unit tests
!tests/fixtures/
!tests/fixtures/**/*.json
# Exception: Playwright e2e specs are tracked so CI can run them
!tests/e2e/
tests/e2e/*
!tests/e2e/*.spec.ts
docs/
scripts/
playwright-report/
test-results/
*.original.md
.superpowers/
.worktrees/

# Signing keys (never commit private keys)
~/.tauri/

# Generated screenshots and playwright artifacts
.playwright-mcp/
skill-observations/
# Root-level screenshots (not src-tauri/icons which are needed for builds)
/*.png
