# Tests, docs, scripts — not needed to build
tests/*
# Exceptions: tracked tests
!tests/unit/
!tests/unit/**/*.spec.ts
# Exception: the WCAG contrast lint is tracked so CI can run it
# (the existing `tests/test_*.js` runner picks it up automatically).
!tests/test_contrast.js
docs/
scripts/
playwright-report/
test-results/
*.original.md
.superpowers/

# Signing keys (never commit private keys)
~/.tauri/

# Generated screenshots and playwright artifacts
.playwright-mcp/
skill-observations/
# Root-level screenshots (not src-tauri/icons which are needed for builds)
/*.png
